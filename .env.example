# ============================================================
# Android AI Studio Template — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Optional: GitHub Token for gh CLI operations
# The gh CLI uses GH_TOKEN (not GITHUB_PAT) for authentication.
# Required only if your app or CI integrates with the GitHub API / gh CLI.
# Grant the minimum required scopes (e.g. repo, read:org).
GH_TOKEN=your_github_token_here

# Optional: Codacy project token for coverage upload
# Do not uncomment this placeholder to avoid the Secrets plugin generating
# empty fields; instead, export this token in your local terminal shell
# or add it as a GitHub Actions secret.
# CODACY_PROJECT_TOKEN=your_codacy_project_token_here
