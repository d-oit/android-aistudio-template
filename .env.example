# ============================================================
# Android AI Studio Template — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Required: Google AI Studio API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Personal Access Token
# Required only if your app integrates with the GitHub API
GITHUB_PAT=your_github_personal_access_token_here

# Optional: Codacy project token for coverage upload
CODACY_PROJECT_TOKEN=your_codacy_project_token_here

# Optional: Release signing config (for local release builds)
KEYSTORE_PATH=./keystore/release.jks
KEYSTORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=
